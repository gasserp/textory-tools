{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Textory",
  "version": "0.1.0",
  "identifier": "dev.textory.desktop",
  "build": {
    "frontendDist": "../../app/dist",
    "beforeBuildCommand": "npm run build:native -w app --prefix ..",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev -w app --prefix .."
  },
  "app": {
    "windows": [
      {
        "title": "textory",
        "width": 900,
        "height": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://textory.dev; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
